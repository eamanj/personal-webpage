@article{interference_mediation,
  title={Causal Inference under Endogenous Network Interference: A Design-Based Mediation Framework},
  author={Eaman Jahani},
  abstract={
  Standard methodologies for causal inference under network interference typically rely on the  assumption that the social network mediating peer influence is measured pre-treatment and  remains static. However, in many practical settings, ranging from public health interventions  to digital platform optimizations, the treatment itself endogenously alters the network  topology. In such scenarios, using the pre-treatment network snapshot to define exposure conditions leads to severe exposure misspecification and biased causal estimates.
  This paper investigates the inferential challenges posed by endogenous, treatment-induced network evolution and introduces a design-based mediation framework to recover meaningful causal estimands under network interference.
  We first formally characterize the bias in standard Horvitz-Thompson estimators that arises  when researchers utilize pre-treatment networks to define target exposures. We prove that  this bias is driven by the probability of misclassification and the outcome  discrepancy between valid and invalid exposure states.
  To resolve this, we introduce a design-based mediation perspective that conceptualizes the post-treatment network as a  high-dimensional mediator between the randomization design and observed outcomes. 
  This framework orthogonally decomposes the global Average Treatment Effect (ATE) into  two distinct causal pathways: the Natural Direct Effect (NDE), which captures effects  operating through the treatment while holding the network distribution fixed, and the  Natural Indirect Effect (NIE), which captures effects operating strictly through  treatment-induced shifts in the network structure.
  We establish the conditions for valid inference on these mediated estimands and develop unbiased inverse-probability weighted (IPW) estimators. We further prove their consistency and asymptotic normality under sparse dependence and derive conservative variance estimators to facilitate valid inference despite the structural unobservability of joint counterfactual propensities.
  Analytic evaluations and  Monte Carlo simulations demonstrate that our proposed estimators effectively eliminate  finite-sample bias and maintain valid nominal coverage, providing the methodological framework for disentangling the direct efficacy of an intervention from indirect and structural channels in dynamic environments.
  },
  category={Working papers}
}


@article{network_hatespeech,
  title={Celebrity messages reduce online hate and limit its spread},
  author={Eaman Jahani and Blas Kolic and Manuel Tonneau and Hause Lin and Daniel Barkoczi and Edwin Ikhuoria and Victor Orozco and Samuel Fraiberger},
  abstract={
  Online hate spreads rapidly, yet little is known about whether preventive and scalable strategies can curb it. We conducted the largest randomized controlled trial of hate speech prevention to date: a 20-week messaging campaign on X in Nigeria targeting ethnic hate. 73,136 users who had previously engaged with hate speech were randomly assigned to receive prosocial video messages from Nigerian celebrities. The campaign reduced hate content by 2.5% to 5.5% during treatment, with about 75% of the reduction persisting over the following four months. Reaching a larger share of a user's audience reduced amplification of that user's hate posts among both treated and untreated users, cutting hate reposts by over 50% for the most exposed accounts. Scalable messaging can limit online hate without removing content.
  },
  category={Working papers},
  html={https://arxiv.org/abs/2601.04134}
}


@article{unequal_diffusion,
  title={Network Structure of Unequal Diffusion},
  author={Eaman Jahani and Dean Eckles and Alex Pentland},
	abstract={
	We develop a theoretical network model that captures the network structure of unequal
	diffusion.  First, we argue that homophily alone does not fully
	explain the extent of unequal diffusion in the network.  We show that any departure from
	the uniform distribution of links to information sources among members of a group limits
	the diffusion of information to the group as a whole. The variation from equal
	opportunity baseline not only has first order effects since some individuals will have
	fewer direct links to information sources, but also second order effects as the whole
	group will have fewer diffusion paths to the information sources.  Second, we show
	empirically that most networks exhibit higher susceptibility to unequal diffusion across
	various grouping variables (e.g. gender or race) than expected simply by measures of
	homophily. Finally, we develop a variant of the Stochastic Block Model that
	parameterizes the cross-group linking of each node and by doing so fits not only
	assortativity on paths of length 1, but also diffusion assortativity on paths of
	length 2 and 3.
	},
	category={Working papers},
 	html={https://arxiv.org/abs/2210.11053},
  pdf={Unequal_Diffusion_JASA.pdf}
}


article{long_ties_fundraising,
  title={Tie Strength and Length in Social Capital: Evidence from Charitable Fundraising},
  author={Eaman Jahani, Michael Bailey, and Dean Eckles},
	abstract={
		We contribute to the literature on network structure and performance by studying the
		local network structure around individuals with the best outcomes. We propose the
		concept of bandwidth-diversity matching, according to which individuals who match
		the tie strength to their contacts with their structural novelty achieve truly
		diverse networks and obtain better outcomes. We investigate this in the context of
		birthday fundraisers on Facebook. We show that users whose networks is composed of
		a mixture of short embedded ties and long ties are more likely to reach their
		fundraiser goal than those with one type exclusively. More importantly, the
		stronger the long ties are, the more successful the campaign will be. In other
		words, the most successful fundraisers occur when the ego has cultivated a mix of
		embedded ties and strong-long ties.},
	category={Working papers}
}


article{inequality_experiment,
  title={Rivalrous Resource Sharing in Networks can Exacerbate Existing Inequalities},
  author={Eaman Jahani, Dean Eckles},
	abstract={
		We examine the network mechanisms that widen inter-group differences and lead to different
		levels of  social capital in different groups. We study an information sharing game, in
		which individuals have to compete for a rivalrous resource over repeated rounds. The
		equilibrium predicts lower cooperation among lower status agents, which leads the whole
		group to receive a small share of the common resource. We further validate this
		prediction in an online lab experiment by recruiting individuals to play an online
		collaborative game in which they have to find and dig gold mines and in the process can
		pass information to their neighbors according to the network structure. The players
		which had a lower chance of receiving the gold were less likely to share it with their
		contacts. As a result, these low status players took ``a smaller share of the pie'' than
		what was expected by their individual differences.
	},
	category={Working papers},
	pdf={rivalrous_resource_sharing_in_networks.pdf},
}

@article{prompt_engineering,
  author = {Eaman Jahani and Benjamin Manning and Joe Zhang and Hong-Yi TuYe and Mohammed Alsobay and Christos Nicolaides and Siddharth Suri and David Holtz},
  title = {Prompt Adaptation as a Dynamic Complement in Generative AI Systems},
  journal = {Information Systems Research},
  year = {2026},
  doi = {10.1287/isre.2025.2029},
  abstract = { Do users automatically benefit when generative AI models improve, or does realizing those gains require changing how they interact with the technology? We ran two preregistered experiments with 3,750 participants submitting nearly 37,000 prompts across two versions of OpenAI’s DALL-E to find out. The answer depends critically on task structure. In a bounded task with a clear objective, replicating a specific target image, roughly half of the performance gain came from the model itself, and half came from users naturally adjusting their prompts. In an open-ended creative task, designing logos for hypothetical organizations, nearly all of the improvement was attributable to the model alone. We then asked whether automated prompt rewriting, a feature embedded in many commercial AI products, could substitute for this user adaptation. It could not: rewriting modestly helped in the creative task but substantially hurt performance in the replication task, where precise user control mattered most. For organizations deploying AI in precision-oriented workflows, our results point to an underappreciated priority: investing in how people learn to interact with a model may matter as much as the model itself. },
  category={Refereed},
  html={https://pubsonline.informs.org/doi/10.1287/isre.2025.2029}
}


@article{long_ties_formation,
  author = {Eaman Jahani  and Samuel P. Fraiberger  and Michael Bailey  and Dean Eckles},
  title = {Long ties, disruptive life events, and economic prosperity},
  journal = {Proceedings of the National Academy of Sciences},
  volume = {120},
  number = {28},
  pages = {e2211062120},
  year = {2023},
  doi = {10.1073/pnas.2211062120},
  eprint = {https://www.pnas.org/doi/pdf/10.1073/pnas.2211062120},
  abstract = {Social networks shape and reflect economic life. Prior studies have
  identified long ties, which connect people who lack mutual contacts, as a correlate of
  individuals’ success within firms and places’ economic prosperity. However, we lack
  population-scale evidence of the individual-level link between long ties and
  economic prosperity, and why some people have more long ties remains obscure. Here,
  using a social network constructed from interactions on Facebook, we establish a
  robust association between long ties and economic outcomes and study disruptive life
  events hypothesized to cause formation of long ties. Consistent with prior
  aggregated results, administrative units with a higher fraction of long ties tend to
  have higher-income and economic mobility. Individuals with more long ties live in
  higher-income places and have higher values of proxies for economic prosperity
  (e.g., using more Internet-connected devices and making more donations).
  Furthermore, having stronger long ties (i.e., with higher intensity of interaction)
  is associated with better outcomes, consistent with an advantage from the structural
  diversity constituted by long ties, rather than them being weak ties per se. We then
  study the role of disruptive life events in the formation of long ties. Individuals
  who have migrated between US states, have transferred between high schools, or have
  attended college out-of-state have a higher fraction of long ties among their
  contacts many years after the event. Overall, these results suggest that long ties
  are robustly associated with economic prosperity and highlight roles for important
  life experiences in developing and maintaining long ties.},
  html={https://www.pnas.org/doi/abs/10.1073/pnas.2211062120},
	category={Refereed}
}


@article{yuan2023implications,
  title={Implications of COVID-19 vaccination heterogeneity in mobility networks},
  author={Yuan Yuan and Eaman Jahani and Shengjia Zhao and Yong-Yeol Ahn and Alex Pentland},
  journal={Communications Physics},
  volume={6},
  number={1},
  pages={206},
  year={2023},
  publisher={Nature Publishing Group UK London},
  abstract={Our study utilizes network science to examine how uneven vaccine distribution
  affects mass vaccination strategies in the United States. Using mobility network data
  and epidemiological models, we find that distributing a fixed quantity of additional
  vaccines across Census Block Groups (CBGs) can vary case count reductions by up to
  200l\%. This highlights the impact of vaccination heterogeneity in mobility networks
  on epidemic outcomes. Our efficient algorithm identifies optimal vaccine
  distribution for maximum case reduction. Simulations show a possible 9.5\% decrease
  in case numbers with just a 1\% increase in the national vaccination rate if
  vaccines are optimally distributed. This result surpasses those from other vaccine
  distribution models. Our findings underline the need for policymakers to understand
  the interaction between vaccination patterns and mobility networks, suggesting that
  grasping geographical vaccine uptake variations could be as crucial as raising the
  overall vaccination rate.},
  html={https://www.nature.com/articles/s42005-023-01325-7},
	category={Refereed}
}


@article{common_enemy,
  title={An Online experiment during the 2020 US--Iran crisis shows that exposure to common enemies can increase political polarization},
  url={https://doi.org/10.1038/s41598-022-23673-0},
  publisher={Nature Publishing Group},
  author={Eaman Jahani and Natalie M. Gallagher and Friedolin Merhout and Nicolo Cavalli and Douglas Guilbeault and Yan Leng and Christopher A. Bail},
  year={2022},
  month={July},
  journal={Scientific Reports},
  volume={12},
  number={1},
  pages={1--8},
  year={2022},
	abstract={Longstanding theory indicates a common enemy can mitigate conflict between
	members of rival groups. We tested this hypothesis in a pre-registered experiment
	where 1,670 Republicans and Democrats in the United States were asked to complete a
	collaborative online task with an automated agent or ``bot" that was labelled as a
	member of the opposing party. Prior to this task, we exposed respondents to primes
	about a) a common enemy (involving threats from Iran, China, and Russia); b) a
	patriotic event; or c) a neutral, apolitical prime. Though we observed no
	significant differences in the behavior of Democrats as a result of these primes, we
	found that Republicans—and particularly those with very strong conservative
	views—were significantly less likely to cooperate with Democrats when primed about a
	common enemy. We also observed lower rates of cooperation among Republicans who
	participated in our study during the 2020 Iran crisis, which occurred in the middle
	of our data collection. These findings indicate common enemies may not reduce
	inter-group conflict in highly polarized societies, and contribute to a growing
	number of studies that find evidence of asymmetric political polarization. We
	conclude by discussing the implications of these findings for research in social
	psychology, political conflict, and the rapidly expanding field of computational
	social science.},
 	html={https://rdcu.be/c0htY},
  pdf={Common_Enemies _MS_ScientificReports.pdf},
	category={Refereed}
}

@article{misinformation_whatsapp,
  author = {Irene V. Pasquetto and Eaman Jahani and Shubham Atreja and Matthew Baum},
  title = {Social Debunking of Misinformation on WhatsApp: The Case for Strong and In-Group Ties},
  year = {2022},
  issue_date = {April 2022},
  publisher = {Association for Computing Machinery},
  address = {New York, NY, USA},
  volume = {6},
  number = {CSCW1},
  url = {https://doi.org/10.1145/3512964},
  html = {https://dl.acm.org/doi/abs/10.1145/3512964},
	pdf = {whatsapp_misinfo.pdf},
  doi = {10.1145/3512964},
  abstract = {In this paper, we argue that WhatsApp can play an important role in correcting misinformation. We show how specific WhatsApp affordances (flexibility in format and audience selection) and existing social capital (prevalence of strong ties; homophily in political groups) can be leveraged to maximize the re-sharing of debunking messages, such as those accessed by WhatsApp users via ChatBots and Tip-Lines. Debunking messages received in the format of audio files generated more interest and were more effective in correcting beliefs than text- or image-based messages. In addition, we found clear evidence that users re-share debunks at higher rates when they received them from people close to them (strong ties), from individuals who generally agree with them politically (in-group members), or when both conditions are met. We suggest that WhatsApp leverages our findings to maximize the re-share of those fact-checks that are already circulating on the platform by using the existing social capital in the network, unlocking the potential for such debunks to reach a larger audience on WhatsApp.},
  journal = {Proc. ACM Hum.-Comput. Interact.},
  month = {apr},
  articleno = {117},
  numpages = {35},
	category = {Refereed},
}

@article{jahani2018scamcoin,
	author = {Eaman Jahani and Eaman and Krafft, Peter and Suhara, Yoshiko and Moro, Esteban and Pentland, Alex},
	title = {ScamCoins, S*** Posters, and the Search for the Next Bitcoin<sup>TM</sup>: Collective Sensemaking in Cryptocurrency Discussions},
	year = {2018},
	issue_date = {November 2018},
	publisher = {Association for Computing Machinery},
	address = {New York, NY, USA},
	volume = {2},
	number = {CSCW},
	url = {https://doi.org/10.1145/3274348},
	html = {https://dl.acm.org/doi/abs/10.1145/3274348},
	pdf={cscw.pdf},
	doi = {10.1145/3274348},
	abstract = {Participants in cryptocurrency markets are in constant communication with each other about the latest coins and news releases. Do these conversations build hype through the contagiousness of excitement, help the community process information, or play some other role? Using a novel dataset from a major cryptocurrency forum, we conduct an exploratory study of the characteristics of online discussion around cryptocurrencies. Through a regression analysis, we find that coins with more information available and higher levels of technical innovation are associated with higher quality discussion. People who talk about "serious" coins tend to participate in discussion displaying signatures of collective intelligence and information processing, while people who talk about "less serious" coins tend to display signatures of hype and na\"{\i}vety. Interviews with experienced forum members also confirm these quantitative findings. These results highlight the varied roles of discussion in the cryptocurrency ecosystem and suggest that discussion of serious coins may be oriented towards earnest, perhaps more accurate, attempts at discovering which coins are likely to succeed.},
	journal = {Proc. ACM Hum.-Comput. Interact.},
	month = nov,
	articleno = {79},
	numpages = {28},
	category={Refereed},
	keywords = {computational social science, online discussion, cryptocurrency, information processin, collective intelligence},
}

@article{jahani2017improving,
  title={Improving official statistics in emerging markets using machine learning and mobile phone data},
  author={Eaman Jahani and Pal Sunds{\o}y and Johannes Bjelland and Linus Bengtsson and Alex Pentland and Yves Alexandre de Montjoye},
  journal={EPJ Data Science},
  volume={6},
  number={1},
  pages={3},
  year={2017},
	issue_date = {June 2017},
	abstract = {Mobile phones are one of the fastest growing technologies in the developing
	world with global penetration rates reaching 90\%. Mobile phone data, also called CDR,
	are generated everytime phones are used and recorded by carriers at scale. CDR have
	generated groundbreaking insights in public health, official statistics, and
	logistics. However, the fact that most phones in developing countries are prepaid
	means that the data lacks key information about the user, including gender and other
	demographic variables. This precludes numerous uses of this data in social science
	and development economic research. It furthermore severely prevents the development
	of humanitarian applications such as the use of mobile phone data to target aid
	towards the most vulnerable groups during crisis. We developed a framework to
	extract more than 1400 features from standard mobile phone data and used them to
	predict useful individual characteristics and group estimates. We here present a
	systematic cross-country study of the applicability of machine learning for dataset
	augmentation at low cost. We validate our framework by showing how it can be used to
	reliably predict gender and other information for more than half a million people in
	two countries. We show how standard machine learning algorithms trained on only
	10,000 users are sufficient to predict individual’s gender with an accuracy ranging
	from 74.3 to 88.4\% in a developed country and from 74.5 to 79.7\% in a developing
	country using only metadata. This is significantly higher than previous approaches
	and, once calibrated, gives highly accurate estimates of gender balance in groups.
	Performance suffers only marginally if we reduce the training size to 5,000, but
	significantly decreases in a smaller training set. We finally show that our
	indicators capture a large range of behavioral traits using factor analysis and that
	the framework can be used to predict other indicators of vulnerability such as age
	or socio-economic status. Mobile phone data has a great potential for good and our
	framework allows this data to be augmented with vulnerability and other information
	at a fraction of the cost.},
  publisher={Springer},
	url={https://doi.org/10.1140/epjds/s13688-017-0099-3},
	doi={10.1140/epjds/s13688-017-0099-3},
	category={Refereed},
	html = {https://link.springer.com/article/10.1140/epjds/s13688-017-0099-3},
	pdf={epj.pdf},
}


@InProceedings{jahani2017differential,
	author={Eaman Jahani and Guillaume Saint-Jacques and Pal Sunds{\o}y and Johannes Bjelland and Esteban Moro and Alex Pentland},
	title="Differential Network Effects on Economic Outcomes: A Structural Perspective",
	booktitle="Social Informatics.",
	year="2017",
	publisher="Springer International Publishing",
	address="Cham",
	pages="41--50",
	abstract="In a study of about 33,000 individuals in a south Asian country, we find that structural diversity, measured as the fraction of open triads in an ego-network, shows a relatively strong association with individual income. After including all the relevant control variables, the effect of structural diversity becomes exclusive to the highly educated individuals. We hypothesize these results are due to concentrated distribution of economic opportunities among the highly educated social strata combined with homophily among members of the same group. This process leads to two important societal consequences: extra network advantages for the highly educated, similar to the rich club effect, and inadequate diffusion of economic opportunities to the low educated social strata.",
	isbn="978-3-319-67256-4",
	category={Lightly refereed},
	html = {https://link.springer.com/chapter/10.1007/978-3-319-67256-4_5},
	pdf={socInfo.pdf},
}

